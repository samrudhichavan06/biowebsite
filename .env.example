VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
VITE_ADMIN_USERNAME=admin
VITE_ADMIN_PASSWORD=BioEnergy@2026

# Email delivery: configure AWS SES.
# Note: SES sandbox mode requires sender and recipient emails to be verified in the same region.
#       Request production access to send to arbitrary attendee addresses.
#       For this application, use the verified sender address below.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_SES_FROM_EMAIL=sidbixx@gmail.com
