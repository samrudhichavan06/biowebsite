VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
VITE_ADMIN_USERNAME=admin
VITE_ADMIN_PASSWORD=BioEnergy@2026

# Email delivery: configure AWS SES.
# Note: SES sandbox mode requires sender and recipient emails to be verified in the same region.
#       Request production access to send to arbitrary attendee addresses.
#       For this application, use the verified sender address below.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_SES_FROM_EMAIL=sidbixx@gmail.com

# Razorpay keys
# Put your public key here (used by the client build)
VITE_RZP_KEY_ID=rzp_test_your_public_key_here
# Server-side key id (same as public key id)
RZP_KEY_ID=rzp_test_your_key_id_here
# Server-side secret (DO NOT COMMIT - set this on your host or in a local .env)
RZP_KEY_SECRET=rzp_test_your_key_secret_here
# Webhook secret configured in Razorpay dashboard (server-only)
RZP_WEBHOOK_SECRET=your_webhook_secret_here

# Optional: Firebase service account JSON (stringified) for server-side persistence
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
